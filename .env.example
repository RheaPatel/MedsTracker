# --- Community database (Neon Postgres) ---
# REQUIRED for the shared/community features in production.
# If left UNSET, the API falls back to a local JSON file at ./data/reports.json
# so you can run and demo the whole app locally with zero setup.
#
# Get a free connection string at https://neon.tech (it looks like the line below).
# DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Port for the local API server (vite proxies /api here in dev).
PORT=3001
